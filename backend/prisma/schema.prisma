// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Branch {
  id        String    @id @default(cuid())
  name      String
  location  String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  cashiers  Cashier[]
  users     User[]
}

model Cashier {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  phone     String?
  branchId  String
  branch    Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([branchId])
}

model User {
  id             String        @id @default(cuid())
  name           String
  email          String        @unique
  password       String
  employeeNumber String
  phone          String
  role           Role          @default(USER)
  balance        Decimal       @default(0) @db.Decimal(10, 2)
  qrCode         String        @unique
  isActive       Boolean       @default(true)
  isBlocked      Boolean       @default(false)
  blockReason    String?
  minBalance     Decimal       @default(0) @db.Decimal(10, 2) // Alertar si balance < minBalance
  branchId       String?
  branch         Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  transactions   Transaction[]
  recharges      Recharge[]

  @@index([branchId])
}

model Transaction {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           TransactionType
  amount         Decimal         @db.Decimal(10, 2)
  balanceBefore  Decimal?        @db.Decimal(10, 2)
  balanceAfter   Decimal?        @db.Decimal(10, 2)
  description    String
  status         String          @default("COMPLETED")
  cashierId      String?
  paymentMethod  PaymentMethod?
  reference      String?
  createdAt      DateTime        @default(now())

  items          TransactionItem[]

  @@index([userId])
  @@index([createdAt])
}

model Recharge {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount         Decimal        @db.Decimal(10, 2)
  paymentMethod  PaymentMethod
  status         RechargeStatus @default(PENDING)
  reference      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId])
  @@index([status])
}

enum Role {
  USER
  CASHIER
  ADMIN
}

enum TransactionType {
  PURCHASE
  RECHARGE
  REFUND
}

enum PaymentMethod {
  CASH
  STRIPE
  MERCADOPAGO
}

enum RechargeStatus {
  PENDING
  COMPLETED
  FAILED
}

model Product {
  id        String   @id @default(cuid())
  name      String
  price     Decimal  @db.Decimal(10, 2)
  category  String   @default("General")
  image     String?
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactionItems TransactionItem[]

  @@index([branchId])
}

model TransactionItem {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  quantity      Int         @default(1)
  unitPrice     Decimal     @db.Decimal(10, 2)
  subtotal      Decimal     @db.Decimal(10, 2)

  @@index([transactionId])
  @@index([productId])
}

model CashierSession {
  id           String    @id @default(cuid())
  cashierId    String
  branchId     String
  branch       Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  initialFloat Decimal   @default(0) @db.Decimal(10, 2)
  finalBalance Decimal?  @db.Decimal(10, 2)
  totalCharges Decimal   @default(0) @db.Decimal(10, 2)
  status       String    @default("OPEN") // OPEN, CLOSED, RECONCILED
  notes        String?

  @@index([branchId])
}

model UserAlert {
  id        String   @id @default(cuid())
  userId    String
  type      String   // LOW_BALANCE, BLOCKED, etc
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
