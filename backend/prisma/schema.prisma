// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Plan {
  id              String    @id @default(cuid())
  name            String    @unique  // ENTERPRISE, LITE
  description     String?
  price           Decimal   @db.Decimal(10, 2)
  billingCycle    String    @default("MONTHLY") // MONTHLY, YEARLY, ONETIME
  maxBranches     Int       @default(1)
  maxUsersPerBranch Int?    // null = unlimited
  features        String[]  // JSON array de features
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subscriptions   Subscription[]
}

model Subscription {
  id              String    @id @default(cuid())
  planId          String
  plan            Plan      @relation(fields: [planId], references: [id])

  status          String    @default("ACTIVE") // ACTIVE, EXPIRED, BLOCKED, CANCELLED
  startDate       DateTime  @default(now())
  endDate         DateTime
  renewalDate     DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  company         Company?

  @@index([planId])
}

model Company {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique @default(cuid())
  email           String    @unique
  phone           String?
  industry        String?   // Restaurante, Cafetería, etc.

  // Plan y Suscripción (one-to-one)
  subscriptionId  String?   @unique
  subscription    Subscription? @relation(fields: [subscriptionId], references: [id])

  // Información de Pago
  contactPerson   String?
  paymentEmail    String?

  // Facturación (comentado temporalmente - agregar después con migration)
  // licenseFee      Decimal   @default(0) @db.Decimal(10, 2)
  // hostingFee      Decimal   @default(0) @db.Decimal(10, 2)
  // licenseRenewalDate DateTime?
  // nextBillingDate DateTime?
  // additionalBranches Int @default(0)

  // Status
  isActive        Boolean   @default(true)
  isBlocked       Boolean   @default(false)
  blockReason     String?

  // Master Admin de esta empresa
  masterAdminEmail String?

  // Auditoría
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  branches        Branch[]
  payments        CompanyPayment[]
  // invoices        CompanyInvoice[]

  @@index([subscriptionId])
}

model CompanyPayment {
  id              String    @id @default(cuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  amount          Decimal   @db.Decimal(10, 2)
  status          String    @default("PENDING") // PENDING, PAID, FAILED
  description     String?
  invoiceNumber   String?

  paymentDate     DateTime?
  dueDate         DateTime

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([companyId])
}

