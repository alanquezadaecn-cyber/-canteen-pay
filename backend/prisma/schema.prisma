model Branch {
  id              String    @id @default(cuid())
  companyId       String
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  name            String
  slug            String    @default(cuid())
  location        String?
  isActive        Boolean   @default(true)

  // Licencia y Pago
  licenseStatus   String    @default("ACTIVE") // ACTIVE, EXPIRED, BLOCKED, TRIAL
  licenseExpiry   DateTime?
  isBlocked       Boolean   @default(false)
  blockReason     String?

  // Información de Pago (hereda de Company)
  monthlyFee      Decimal   @default(0) @db.Decimal(10, 2)
  lastPaymentDate DateTime?
  nextPaymentDate DateTime?

  // Auditoría
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  cashiers        Cashier[]
  users           User[]
  payments        BranchPayment[]
  products        Product[]
  cashierSessions CashierSession[]

  @@index([companyId])
}

model BranchPayment {
  id          String   @id @default(cuid())
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  amount      Decimal  @db.Decimal(10, 2)
  status      String   @default("PENDING") // PENDING, PAID, FAILED
  description String?
  paymentDate DateTime?
  dueDate     DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([branchId])
}

model Cashier {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  phone     String?
  branchId  String
  branch    Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([branchId])
}

model User {
  id             String        @id @default(cuid())
  name           String
  email          String        @unique
  password       String
  employeeNumber String
  phone          String
  role           Role          @default(USER)
  balance        Decimal       @default(0) @db.Decimal(10, 2)
  qrCode         String        @unique
  isActive       Boolean       @default(true)
  isBlocked      Boolean       @default(false)
  blockReason    String?
  minBalance     Decimal       @default(0) @db.Decimal(10, 2)
  dailyLimit     Decimal       @default(0) @db.Decimal(10, 2)
  photoUrl       String?
  branchId       String?
  branch         Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  transactions   Transaction[]
  recharges      Recharge[]

  @@index([branchId])
}

model Transaction {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           TransactionType
  amount         Decimal         @db.Decimal(10, 2)
  balanceBefore  Decimal?        @db.Decimal(10, 2)
  balanceAfter   Decimal?        @db.Decimal(10, 2)
  description    String
  status         String          @default("COMPLETED")
  cashierId      String?
  paymentMethod  PaymentMethod?
  reference      String?
  createdAt      DateTime        @default(now())

  items          TransactionItem[]

  @@index([userId])
  @@index([createdAt])
}

model Recharge {
  id             String         @id @default(cuid())
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount         Decimal        @db.Decimal(10, 2)
  paymentMethod  PaymentMethod
  status         RechargeStatus @default(PENDING)
  reference      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([userId])
  @@index([status])
}

enum Role {
  USER
  CASHIER
  ADMIN
}

enum TransactionType {
  PURCHASE
  RECHARGE
  REFUND
}

enum PaymentMethod {
  CASH
  STRIPE
  MERCADOPAGO
}

enum RechargeStatus {
  PENDING
  COMPLETED
  FAILED
}

model Product {
  id        String   @id @default(cuid())
  name      String
  price     Decimal  @db.Decimal(10, 2)
  category  String   @default("General")
  image     String?
  branchId  String?
  branch    Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  isActive  Boolean  @default(true)
  stock     Int      @default(-1)
  minStock  Int      @default(0)
  isTracked Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactionItems TransactionItem[]
  stockMovements   StockMovement[]

  @@index([branchId])
}

model StockMovement {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type      String
  quantity  Int
  prevStock Int
  newStock  Int
  note      String?
  createdBy String?
  createdAt DateTime @default(now())

  @@index([productId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  details   String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model TransactionItem {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  quantity      Int         @default(1)
  unitPrice     Decimal     @db.Decimal(10, 2)
  subtotal      Decimal     @db.Decimal(10, 2)

  @@index([transactionId])
  @@index([productId])
}

model CashierSession {
  id           String    @id @default(cuid())
  cashierId    String
  branchId     String
  branch       Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  initialFloat Decimal   @default(0) @db.Decimal(10, 2)
  finalBalance Decimal?  @db.Decimal(10, 2)
  totalCharges Decimal   @default(0) @db.Decimal(10, 2)
  status       String    @default("OPEN") // OPEN, CLOSED, RECONCILED
  notes        String?

  @@index([branchId])
}

model UserAlert {
  id        String   @id @default(cuid())
  userId    String
  type      String   // LOW_BALANCE, BLOCKED, etc
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
